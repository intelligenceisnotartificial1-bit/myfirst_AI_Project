{
  "name": "shophub-ecommerce",
  "version": "1.0.0",
  "description": "Beautiful 3D e-commerce landing page for Shopify stores with Pakistani payment gateway integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "webpack --config webpack.config.js",
    "build:prod": "webpack --config webpack.config.js --mode production",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "serve": "http-server -p 8000",
    "shopify:dev": "shopify theme dev",
    "shopify:push": "shopify theme push",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "security:audit": "npm audit",
    "security:check": "snyk test",
    "performance:test": "lighthouse https://yoursite.com --chrome-flags='--headless --no-sandbox'",
    "docker:build": "docker build -t shophub:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "keywords": [
    "ecommerce",
    "shopify",
    "landing-page",
    "3d",
    "payment-gateway",
    "pakistan",
    "jazzcash",
    "easypaisa",
    "stripe"
  ],
  "author": "ShopHub Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.7.0",
    "axios": "^1.4.0",
    "stripe": "^12.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "express-validator": "^7.0.0",
    "redis": "^4.6.0",
    "pg": "^8.10.0",
    "sequelize": "^6.31.0",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1400.0",
    "shopify-api": "^9.0.0",
    "nodemailer": "^6.9.3",
    "chalk": "^4.1.2",
    "winston": "^3.8.2",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "three": "^r128",
    "gsap": "^3.12.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "jest": "^29.6.1",
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "babel-loader": "^9.1.2",
    "eslint": "^8.43.0",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "http-server": "^14.1.1",
    "shopify-cli": "^3.53.0",
    "vercel": "^31.0.0",
    "netlify-cli": "^15.3.0",
    "snyk": "^1.1218.0",
    "lighthouse": "^9.6.8",
    "artillery": "^2.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/shophub.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/shophub/issues"
  },
  "homepage": "https://shophub.com",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "browser": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": "latest"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "warn"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 4,
    "semi": true
  }
}
