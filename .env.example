# =============================================
# SHOPHUB ENVIRONMENT CONFIGURATION
# =============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# =============================================
# APPLICATION SETTINGS
# =============================================
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=ShopHub
ADMIN_EMAIL=admin@shophub.com

# =============================================
# JAZZCASH PAYMENT GATEWAY
# =============================================
JAZZCASH_ENABLED=true
JAZZCASH_MERCHANT_ID=your_merchant_id_here
JAZZCASH_PASSWORD=your_password_here
JAZZCASH_MERCHANT_NAME=ShopHub
JAZZCASH_BASE_URL=https://sandbox.jazzcash.com.pk/
JAZZCASH_IS_PRODUCTION=false

# =============================================
# EASYPAISA PAYMENT GATEWAY
# =============================================
EASYPAISA_ENABLED=true
EASYPAISA_STORE_ID=your_store_id_here
EASYPAISA_AUTH_TOKEN=your_auth_token_here
EASYPAISA_BASE_URL=https://sandbox.easypaisa.com.pk/
EASYPAISA_API_ENDPOINT=api/payment/create

# =============================================
# HBL PAYMENT GATEWAY
# =============================================
HBL_ENABLED=true
HBL_MERCHANT_ID=your_merchant_id_here
HBL_TERMINAL_ID=your_terminal_id_here
HBL_ENCRYPTION_KEY=your_encryption_key_here
HBL_BASE_URL=https://payment.hbl.com.pk/

# =============================================
# UBL PAYMENT GATEWAY
# =============================================
UBL_ENABLED=true
UBL_MERCHANT_ID=your_merchant_id_here
UBL_TERMINAL_ID=your_terminal_id_here
UBL_ENCRYPTION_KEY=your_encryption_key_here
UBL_BASE_URL=https://payment.ubl.com.pk/

# =============================================
# STRIPE PAYMENT GATEWAY
# =============================================
STRIPE_ENABLED=true
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================
# CRYPTOCURRENCY PAYMENT GATEWAY
# =============================================
CRYPTO_ENABLED=true
CRYPTO_API_KEY=your_api_key_here
CRYPTO_BASE_URL=https://api.commerce.coinbase.com/
CRYPTO_SUPPORTED_COINS=BTC,ETH,USDC,USDT

# =============================================
# BANK TRANSFER CONFIGURATION
# =============================================
BANK_TRANSFER_ENABLED=true
BANK_ACCOUNT_1_NAME=Habib Bank Limited
BANK_ACCOUNT_1_HOLDER=ShopHub (Pvt) Ltd
BANK_ACCOUNT_1_NUMBER=1234567890123
BANK_ACCOUNT_1_IBAN=PK36HABLC0123456789012345
BANK_ACCOUNT_1_BRANCH=HBKMPKKA

BANK_ACCOUNT_2_NAME=United Bank Limited
BANK_ACCOUNT_2_HOLDER=ShopHub (Pvt) Ltd
BANK_ACCOUNT_2_NUMBER=0987654321098
BANK_ACCOUNT_2_IBAN=PK82UBLCASPS0987654321098
BANK_ACCOUNT_2_BRANCH=UBLEKAHY

# =============================================
# DATABASE CONFIGURATION
# =============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shophub_db
DB_USER=shophub_user
DB_PASSWORD=strong_password_here
DB_SSL=false

# =============================================
# REDIS CONFIGURATION (CACHING)
# =============================================
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================
# EMAIL CONFIGURATION
# =============================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=noreply@shophub.com
MAIL_FROM_NAME=ShopHub

# =============================================
# AWS S3 CONFIGURATION (FILE UPLOADS)
# =============================================
AWS_ENABLED=true
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=shophub-storage
AWS_URL=https://s3.amazonaws.com/shophub-storage

# =============================================
# SHOPIFY CONFIGURATION
# =============================================
SHOPIFY_STORE_NAME=your-store-name
SHOPIFY_ACCESS_TOKEN=your_access_token_here
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_API_VERSION=2024-01

# =============================================
# WEBHOOK CONFIGURATION
# =============================================
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_TIMEOUT=30000
PAYMENT_CALLBACK_URL=https://yourstore.com/api/payment/callback
PAYMENT_RETURN_URL=https://yourstore.com/payment/confirmation

# =============================================
# SECURITY CONFIGURATION
# =============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=https://yourstore.com
CSRF_PROTECTION=true

# =============================================
# LOGGING CONFIGURATION
# =============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
SENTRY_DSN=

# =============================================
# ANALYTICS & MONITORING
# =============================================
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=
HOTJAR_ID=
DATADOG_API_KEY=

# =============================================
# PAYMENT RECONCILIATION
# =============================================
RECONCILIATION_ENABLED=true
RECONCILIATION_INTERVAL=3600000
RECONCILIATION_TIMEOUT=30000
RECONCILIATION_RETRY_COUNT=3

# =============================================
# NOTIFICATION SETTINGS
# =============================================
SMS_ENABLED=true
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_FROM_NUMBER=+923001234567

PUSH_NOTIFICATIONS_ENABLED=true
PUSH_SERVICE=firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_PAYMENT_MAX=10

# =============================================
# FEATURE FLAGS
# =============================================
FEATURE_3D_ANIMATIONS=true
FEATURE_LIVE_CHAT=false
FEATURE_LOYALTY_PROGRAM=false
FEATURE_SUBSCRIPTION=false
FEATURE_AFFILIATE_PROGRAM=false

# =============================================
# DEVELOPMENT SETTINGS
# =============================================
DEBUG=false
VERBOSE_LOGGING=false
HOT_RELOAD=true
SOURCE_MAPS=true
MOCK_PAYMENTS=false

# =============================================
# PRODUCTION SETTINGS (Uncomment for production)
# =============================================
# NODE_ENV=production
# DEBUG=false
# MOCK_PAYMENTS=false
# JAZZCASH_IS_PRODUCTION=true
# DB_SSL=true
# CORS_ORIGIN=https://yourstore.com
# RATE_LIMIT_MAX_REQUESTS=50
